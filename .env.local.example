# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# Supabase
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Postgres connection string for migration + backup scripts
# (scripts/db/migrate.js, scripts/db/backup.js).
# Found in Supabase Dashboard -> Project Settings -> Database
# -> Connection string -> URI. Make sure ?sslmode=require is included.
#
# IMPORTANT: Use the DIRECT connection (port 5432, host db.*.supabase.co),
# NOT the Transaction Pooler (port 6543). The pooler breaks multi-statement
# DDL transactions used by the migration runner.
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres?sslmode=require

# OpenAI API key (dev only — production uses OPENAI_KEY in Vercel env vars)
REACT_APP_OPENAI_KEY=sk-proj-...

# DeepL API key for translation (dev only — production uses DEEPL_KEY in Vercel env vars)
# REACT_APP_DEEPL_KEY is not needed; DeepL is only called server-side via /api/translate
